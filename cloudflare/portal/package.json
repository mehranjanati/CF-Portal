{
	"name": "portal",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"pages:deploy": "npm run build && npx wrangler pages deploy build --project-name nexus-portal --branch main",
